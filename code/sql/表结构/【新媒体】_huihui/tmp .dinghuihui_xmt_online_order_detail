  good_kind_id_level_2 STRING COMMENT '商品类目-二级id',
  good_kind_id_level_3 STRING COMMENT '商品类目-三级id',
  model_type STRING COMMENT '平板型号',
  yjchengb STRING COMMENT '硬件成本金额',
  ramount STRING COMMENT '退款GMV',
  wfs STRING COMMENT '实际支付GMV（又叫退后GMV）',
  zdaren_id STRING COMMENT '达人id弃用',
  qudao STRING COMMENT '支付渠道弃用',
  ldaren_nicheng STRING COMMENT '商务上传达人昵称弃用',
  ldaren_id STRING COMMENT '商务上传达人id弃用',
  kecheng_yongjing STRING COMMENT '平板佣金',
  pinban_yongjing STRING COMMENT '课程佣金',
  jianlian_shangwu STRING COMMENT '建联商务',
  fuwu_shangwu  STRING COMMENT '服务商务',
  hezuo_time STRING COMMENT '达人合作时间',
  daren_type_waibu STRING COMMENT '达人外部等级',
  daren_type_neibu STRING COMMENT '达人内部等级',
  daren_jibie STRING COMMENT '类型',
  diyu STRING COMMENT '无实质含义',
  shifou_kouling STRING COMMENT '无实质含义',
  beiyong1 STRING COMMENT '无实质含义',
  beiyong2 STRING COMMENT '无实质含义',
  beiyong3 STRING COMMENT '无实质含义',
  zuizhong_shangwu STRING COMMENT '无实质含义',
  diff_time STRING COMMENT '无实质含义',
  yongjing_jiner STRING COMMENT '无实质含义'
)

